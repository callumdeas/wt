{
    "compileOnSave": true,
    "compilerOptions": {
        "target": "es2020",
        "module": "NodeNext",
        "outDir": "./dist",
        "moduleResolution": "NodeNext",
        "baseUrl": ".",
        "sourceMap": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "declaration": true,
        "noEmit": false
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "**/*.test.js", "**/*.test.ts"]
}
