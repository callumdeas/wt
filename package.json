{
    "name": "doubleut",
    "author": "Callum Deas",
    "license": "MIT",
    "type": "module",
    "version": "0.0.0",
    "description": "Git worktree manager for bare-repo workflows",
    "keywords": [
        "git",
        "worktree",
        "cli",
        "bare-repo",
        "developer-tools"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CallumDeas/wt.git"
    },
    "homepage": "https://github.com/CallumDeas/wt#readme",
    "bugs": {
        "url": "https://github.com/CallumDeas/wt/issues"
    },
    "bin": {
        "wt": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "prepare": "husky",
        "lint": "npm run lint:prettier && eslint",
        "lint:prettier": "prettier --check '**/*.{md,json,js,ts}'",
        "format": "prettier --write '**/*.{md,json,js,ts}'",
        "test": "jest",
        "test:unit": "jest test/lib/",
        "test:e2e": "npm run build && jest test/e2e/ --testTimeout=60000",
        "ci:test": "npm run build && jest --ci --coverage --reporters=default",
        "build": "rm -rf dist/* && tsc",
        "link": "npm run build && npm link . && chmod +x dist/cli.js"
    },
    "engines": {
        "node": ">=22",
        "npm": ">=8"
    },
    "dependencies": {
        "@inquirer/prompts": "^7.0.0",
        "commander": "^13.0.0",
        "ora": "^9.3.0",
        "picocolors": "^1.1.0",
        "update-notifier": "^7.3.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.14.0",
        "@types/eslint__js": "^8.42.3",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.9.0",
        "@types/update-notifier": "^6.0.8",
        "dotenv": "^16.4.5",
        "eslint": "^9.14.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-unicorn": "^56.0.0",
        "husky": "^9.1.6",
        "jest": "^29.7.0",
        "lint-staged": "^15.2.10",
        "prettier": "^3.3.3",
        "prettier-plugin-organize-imports": "^4.1.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "tsc-files": "^1.1.4",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.13.0"
    },
    "jest": {
        "clearMocks": true,
        "extensionsToTreatAsEsm": [
            ".ts"
        ],
        "moduleNameMapper": {
            "^(\\.{1,2}/.*)\\.js$": "$1"
        },
        "transform": {
            "^.+\\.[tj]sx?$": [
                "ts-jest",
                {
                    "useESM": true
                }
            ]
        },
        "testMatch": [
            "**/?(*.)+(test).[jt]s?(x)"
        ],
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!**/*.test.ts"
        ],
        "coverageReporters": [
            "lcov"
        ],
        "coverageDirectory": "reports",
        "coverageProvider": "v8",
        "testEnvironment": "node",
        "preset": "ts-jest",
        "testLocationInResults": true
    },
    "prettier": {
        "printWidth": 120,
        "tabWidth": 4,
        "plugins": [
            "prettier-plugin-organize-imports"
        ]
    },
    "lint-staged": {
        "*.[jt]s": [
            "eslint --cache"
        ],
        "src/**/*.ts": [
            "tsc-files --noEmit"
        ],
        "*.{md,json,js,ts}": [
            "prettier --write"
        ]
    }
}
